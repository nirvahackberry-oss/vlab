            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Sid\": \"CloudWatchLogs\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"logs:PutLogEvents\",\n        \"logs:GetLogEvents\",\n        \"logs:DescribeLogStreams\",\n        \"logs:CreateLogStream\",\n        \"logs:CreateLogGroup\"\n      ],\n      \"Resource\": \"*\"\n    },\n    {\n      \"Sid\": \"VpcNetworking\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"ec2:UnassignPrivateIpAddresses\",\n        \"ec2:DescribeNetworkInterfaces\",\n        \"ec2:DeleteNetworkInterface\",\n        \"ec2:CreateNetworkInterface\",\n        \"ec2:AssignPrivateIpAddresses\"\n      ],\n      \"Resource\": \"*\"\n    },\n    {\n      \"Sid\": \"EcsExecution\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"ecs:StopTask\",\n        \"ecs:RunTask\",\n        \"ecs:ExecuteCommand\",\n        \"ecs:DescribeTasks\"\n      ],\n      \"Resource\": \"*\"\n    },\n    {\n      \"Sid\": \"PassEcsRoles\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"iam:PassRole\",\n      \"Resource\": [\n        \"arn:aws:iam::465443875617:role/vlab-dev-ecs-task-role\",\n        \"arn:aws:iam::465443875617:role/vlab-dev-ecs-task-execution-role\"\n      ]\n    },\n    {\n      \"Sid\": \"DynamoAccess\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"dynamodb:UpdateItem\",\n        \"dynamodb:Scan\",\n        \"dynamodb:Query\",\n        \"dynamodb:PutItem\",\n        \"dynamodb:GetItem\",\n        \"dynamodb:DeleteItem\"\n      ],\n      \"Resource\": [\n        \"arn:aws:dynamodb:ap-south-1:465443875617:table/vlab-sessions\",\n        \"arn:aws:dynamodb:ap-south-1:465443875617:table/lab-submissions\",\n        \"arn:aws:dynamodb:ap-south-1:465443875617:table/lab-results\"\n      ]\n    },\n    {\n      \"Sid\": \"S3TestCases\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"s3:ListBucket\",\n        \"s3:GetObject\"\n      ],\n      \"Re