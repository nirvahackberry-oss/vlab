            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Sid\": \"CloudWatchLogs\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"logs:PutLogEvents\",\n        \"logs:CreateLogStream\",\n        \"logs:CreateLogGroup\"\n      ],\n      \"Resource\": \"*\"\n    },\n    {\n      \"Sid\": \"VpcNetworking\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"ec2:UnassignPrivateIpAddresses\",\n        \"ec2:DescribeNetworkInterfaces\",\n        \"ec2:DeleteNetworkInterface\",\n        \"ec2:CreateNetworkInterface\",\n        \"ec2:AssignPrivateIpAddresses\"\n      ],\n      \"Resource\": \"*\"\n    },\n    {\n      \"Sid\": \"RunAndDescribeEcsTasks\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"ecs:RunTask\",\n        \"ecs:DescribeTasks\"\n      ],\n      \"Resource\": [\n        \"arn:aws:ecs:ap-south-1:465443875617:task-definition/vlab-dev-python-task:7\",\n        \"arn:aws:ecs:ap-south-1:465443875617:task-definition/vlab-dev-linux-task:3\",\n        \"arn:aws:ecs:ap-south-1:465443875617:task-definition/vlab-dev-java-task:3\",\n        \"arn:aws:ecs:ap-south-1:465443875617:task-definition/vlab-dev-dbms-task:3\",\n        \"arn:aws:ecs:ap-south-1:465443875617:cluster/vlab-dev-cluster\",\n        \"*\"\n      ]\n    },\n    {\n      \"Sid\": \"PassEcsRoles\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"iam:PassRole\",\n      \"Resource\": [\n        \"arn:aws:iam::465443875617:role/vlab-dev-scheduler-stop-lambda-role\",\n        \"arn:aws:iam::465443875617:role/vlab-dev-ecs-task-role\",\n        \"arn:aws:iam::465443875617:role/vlab-dev-ecs-task-execution-role\"\n      ]\n    },\n    {\n      \"Sid\": \"ManageSchedules\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"scheduler:GetSchedule\",\n        \"scheduler:DeleteSchedule\",\n        \"scheduler:CreateSchedule\"\n      ],\n      \"Resource\": [\n        \"arn:aws:scheduler:ap-south-1:465443875617:schedule-group/vl